# RustPlayer — Variables de entorno para API keys
#
# Copia este archivo a .env y rellena los valores antes de compilar.
# NUNCA commitees el .env con valores reales — está en .gitignore.
#
# Uso (Linux/macOS):
#   source .env && cargo build --release
#
# Uso (Windows PowerShell):
#   $env:RUSTPLAYER_LASTFM_KEY="tu_key"; cargo build --release

# ── Last.fm ───────────────────────────────────────────────────────────────────
# Crear en: https://www.last.fm/api/account/create
RUSTPLAYER_LASTFM_KEY=
RUSTPLAYER_LASTFM_SECRET=

# ── OpenSubtitles ─────────────────────────────────────────────────────────────
# Crear en: https://www.opensubtitles.com/en/consumers
RUSTPLAYER_OPENSUBS_KEY=
