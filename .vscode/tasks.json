{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo check",
      "type": "cargo",
      "command": "check",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "cargo run",
      "type": "cargo",
      "command": "run",
      "options": {
        "env": {
          "RUST_LOG": "debug",
          "RUST_BACKTRACE": "1"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "cargo test",
      "type": "cargo",
      "command": "test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "cargo clippy",
      "type": "cargo",
      "command": "clippy",
      "args": [
        "--",
        "-D",
        "warnings"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "cargo fmt",
      "type": "cargo",
      "command": "fmt",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
