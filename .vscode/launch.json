{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug RPlayer (Windows)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/target/debug/rplayer.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "RUST_LOG",
          "value": "debug"
        },
        {
          "name": "RUST_BACKTRACE",
          "value": "1"
        }
      ],
      "preLaunchTask": "cargo check"
    },
    {
      "name": "Debug RPlayer (Windows, file arg)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/target/debug/rplayer.exe",
      "args": [
        "${input:mediaFile}"
      ],
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "RUST_LOG",
          "value": "debug"
        },
        {
          "name": "RUST_BACKTRACE",
          "value": "1"
        }
      ],
      "preLaunchTask": "cargo check"
    },
    {
      "name": "Debug RPlayer (LLDB)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--manifest-path",
          "${workspaceFolder}/Cargo.toml"
        ],
        "filter": {
          "name": "rplayer",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_LOG": "debug",
        "RUST_BACKTRACE": "1"
      }
    }
  ],
  "inputs": [
    {
      "id": "mediaFile",
      "type": "promptString",
      "description": "Ruta del archivo multimedia",
      "default": "C:/ruta/al/archivo.mp4"
    }
  ]
}
