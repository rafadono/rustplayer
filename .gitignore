# ── Rust / Cargo ─────────────────────────────────────────────────────────────
/target/
**/*.rs.bk
# Cargo.lock has been removed from gitignore to ensure reproducible builds

# ── Compiled dependencies / vendor ────────────────────────────────────────────
/vendor/

# ── Build artifacts ───────────────────────────────────────────────────────────
/artifacts/
*.deb
*.rpm
*.tar.gz
*.tar.xz
*.zip

# ── App temporary files ───────────────────────────────────────────────────────
/tmp/rustplayer_thumbs/

# ── Local configuration (contains API keys) ───────────────────────────────────
# DO NOT commit: may contain real keys if the dev put them in code
# Better to use environment variables in production
# src/lastfm.rs        ← do not ignore, but do not commit with real keys
# src/opensubtitles.rs ← ditto

# ── IDEs and editors ──────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.fleet/
.zed/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── VS Code (DO NOT ignore .vscode — committed to share config) ──────────────
# .vscode/       ← INCLUDED intentionally
.vscode/settings.json.local

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
build.log
debug.log

# ── Test coverage ─────────────────────────────────────────────────────────────
/coverage/
lcov.info
*.profraw
*.profdata

# ── CI ────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Windows ───────────────────────────────────────────────────────────────────
*.pdb
*.ilk
*.exp
*.lib

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── CodeGraph ─────────────────────────────────────────────────────────────────
.codegraph/*
!.codegraph/.gitignore
