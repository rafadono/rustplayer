# ── Rust / Cargo ─────────────────────────────────────────────────────────────
/target/
**/*.rs.bk
# Cargo.lock has been removed from gitignore to ensure reproducible builds

# ── Dependencias compiladas / vendor ──────────────────────────────────────────
/vendor/

# ── Artefactos de build ───────────────────────────────────────────────────────
/artifacts/
*.deb
*.rpm
*.tar.gz
*.tar.xz
*.zip

# ── Archivos temporales de la app ─────────────────────────────────────────────
/tmp/rustplayer_thumbs/

# ── Configuración local (contiene API keys) ───────────────────────────────────
# NO commitear: puede contener keys reales si el dev las puso en código
# Mejor usar variables de entorno en producción
# src/lastfm.rs        ← no ignorar, pero no commitear con keys reales
# src/opensubtitles.rs ← ídem

# ── IDEs y editores ───────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.fleet/
.zed/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── VS Code (NO ignorar .vscode — lo commiteamos para compartir config) ───────
# .vscode/       ← INCLUIDO intencionalmente
.vscode/settings.json.local

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
build.log
debug.log

# ── Cobertura de tests ────────────────────────────────────────────────────────
/coverage/
lcov.info
*.profraw
*.profdata

# ── CI ────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Windows ───────────────────────────────────────────────────────────────────
*.pdb
*.ilk
*.exp
*.lib

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
